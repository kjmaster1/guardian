# Normalise all text files to LF in the repository.
# Windows checkouts get CRLF via core.autocrlf; everyone else gets LF.
* text=auto eol=lf

# Force LF for files that must not have CRLF (Makefiles, shell scripts, C source)
Makefile        text eol=lf
*.c             text eol=lf
*.h             text eol=lf
*.py            text eol=lf
*.sh            text eol=lf
*.yml           text eol=lf
*.md            text eol=lf
*.ini           text eol=lf
*.gitignore     text eol=lf
LICENSE         text eol=lf

# Binary files — never touch line endings
*.exe           binary
*.o             binary
*.obj           binary
